            match_history — last {MOCK_HISTORY.length} games
          </span>
        </div>

        <div className={styles.tableWrap}>
          {/* Head */}
          <div className={styles.tableHead}>
            <span>#</span>
            <span>game</span>
            <span>opponent</span>
            <span>result</span>
            <span>elo Δ</span>
