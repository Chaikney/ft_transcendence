OBJ_DIR = obj

OBJS = $(SRC:.cpp=.o)
OBJECTS	= $(addprefix $(OBJ_DIR)/, $(OBJS))

obj/%.o: src/%.cpp
	@mkdir -p obj
	$(CC) $(CFLAGS) -c $< $(INCLUDES) -o $@

$(NAME): $(OBJECTS)
	@echo $(OBJECTS)
	$(CC) $(CFLAGS) $(OBJECTS) $(MLXFLAGS) -o $@ 


all: $(NAME) 


clean:
	$(RM) $(OBJECTS)

fclean: clean
	rm -rf obj
	$(RM) $(NAME)

re: fclean all
