# ==========================================================
# CONFIGURACIÓN DEL ENTORNO (Plantilla)
# Copia este archivo como '.env' en la raíz del proyecto
# para configurar tus propias variables locales.
# ==========================================================

# Modo Mock: 'true' para probar el frontend aislado (sin backend real),
# 'false' para conectar con el backend real.
VITE_USE_MOCK=true

# URL base del backend API
VITE_API_URL=http://localhost:3000/api/v1

# URL para la conexión de WebSockets (ActionCable)
VITE_CABLE_URL=ws://localhost:3000/cable

# Configuración OAuth 42
VITE_42_CLIENT_ID=tu_client_id_aqui
VITE_42_REDIRECT_URI=http://localhost:5173/callback