# Base container version
ALP_VERSION=3.23.4

# Target locations of files *within* the build containers
DB_FILES=/usr/local/pgsql/data
RB_FILES=/usr/src/app
FE_FILES=/var/www
# NOTE If we want the React location, use this line instead
#FE_FILES=/var/www/react/build

# Standard locations and ports for the containers
# TODO Should we have the others here or do they not need to know?
RB_DBHOST=db:5432

# Ruby source code details for the compose file (also present in Dockerfile)
RUBY_VERSION=4.0.5
RUBY_DOWNLOAD_SHA256=7d6149079a63f8ae1d326c9fa65c6019ba2dc3155eae7b39159817911c88958e

# A link to the Ruby source code might be useful too
# RB_SRC=../../ruby
