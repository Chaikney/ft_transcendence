# Base container version
ALP_VERSION=3.23.4
# Ruby source code details for the compose file (also present in Dockerfile)
RUBY_VERSION=4.0.5
RUBY_DOWNLOAD_SHA256=7d6149079a63f8ae1d326c9fa65c6019ba2dc3155eae7b39159817911c88958e
PG_VERSION=
PG_MAJOR=15

# Database Name and User, we judge these to not be worth hiding as secrets
POSTGRES_DB=transcendence_backend_development
POSTGRES_USER=postgres

# Base URL for the application (externally visible)
# NOTE This should be something like hostname -I or localhost
BASE_URL=https://10.13.1.6:8443

VITE_USE_MOCK=false

# NOTE this must match BASE_URL location
VITE_CABLE_URL=wss://10.13.1.6:8443/cable
VITE_API_URL=${BASE_URL}/api
VITE_42_REDIRECT_URI=${BASE_URL}/auth/callback
VITE_BASE_URL=${BASE_URL}

# Authentication with 42 provider
REDIRECT_URI_42=${BASE_URL}/auth/callback
# NOTE this *must* match the 42API_SEC value and have the REDIRECT_URI_42 registered.
UID_42=u-s4t2ud-8b88bb52bf805dfccc6336eeab953398a4f08059160682b5a7ec9138cd3e8e12

# Partial details for sending confirmation emails.
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noctyve.transcendence@gmail.com
SMTP_DOMAIN=gmail.com
