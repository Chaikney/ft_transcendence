    command: bash -c "rm -f tmp/pids/server.pid && bundle exec rails s -p 3000 -b '0.0.0.0'"
    volumes:
      - .:/app  # <--- LA MAGIA: Sincroniza tu carpeta local con el contenedor
    ports:
      - "3000:3000"
    env_file:
      - .env
    depends_on:
      - db

volumes:
